# Django
SECRET_KEY=your-secret-key-here
DEBUG=True

# Cassandra
CASSANDRA_HOST=127.0.0.1
CASSANDRA_PORT=9042
CASSANDRA_KEYSPACE=lms_system

# Cloudflare R2 Storage
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME_PRIVATE=lms-system
R2_BUCKET_NAME_PUBLIC=lms-system-public
R2_ENDPOINT_URL=https://<account_id>.r2.cloudflarestorage.com
R2_PUBLIC_DOMAIN=https://your-public-domain.com

# OmniRoute AI (local LLM proxy)
OMINIROUTE_API_KEY=your-omniroute-api-key
OMINIROUTE_BASE_URL=http://localhost:20128/v1

# Firebase
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=
FIREBASE_CLIENT_ID=
FIREBASE_CLIENT_X509_CERT_URL=
FIREBASE_REGION=asia-southeast1

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CONSUMER_REDIRECT_URI=http://localhost:8000/api/v1/consumer/account/auth/google/callback/
GOOGLE_SPACE_REDIRECT_URI=http://localhost:8000/api/v1/space/account/auth/google/callback/
FRONTEND_CONSUMER_URL=http://localhost:3000
FRONTEND_SPACE_URL=http://localhost:3003

# MoMo Payment (sandbox credentials — replace with production values before go-live)
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=F8BBA842ECF85
MOMO_SECRET_KEY=K951B6PE1waDMi640xX08PD3vg6EkVlz
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create
MOMO_REDIRECT_URL=http://localhost:3000/payment/result
MOMO_IPN_URL=http://localhost:8000/api/v1/consumer/payment/ipn/

# Email Settings
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# STT — local Whisper (faster-whisper, no API key needed, model auto-downloaded on first run)
# Options: tiny (~75MB) | base (~145MB) | small (~465MB)
WHISPER_MODEL=tiny
WHISPER_LANGUAGE=vi

# TTS — Microsoft Edge TTS (free, no API key, requires internet)
# Vietnamese voices: vi-VN-HoaiMyNeural (female) | vi-VN-NamMinhNeural (male)
EDGE_TTS_VOICE=vi-VN-HoaiMyNeural

FACE_SERVICE_URL=http://localhost:8001
FACE_VERIFY_THRESHOLD=0.45

# Typesense
TYPESENSE_HOST=localhost
TYPESENSE_PORT=8108
TYPESENSE_PROTOCOL=http
TYPESENSE_API_KEY=lms-secret-key
TYPESENSE_ENABLED=True
