+[project]
+name = "lms-face-service"
+version = "0.1.0"
+description = "Face recognition microservice for LMS exam proctoring"
+requires-python = ">=3.10,<3.14"
+dependencies = [
+    "fastapi>=0.115.0",
+    "uvicorn[standard]>=0.32.0",
